<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | CV Builder</title>
    <link rel="stylesheet" href="style.css">
</head>
<body class="dashboard-body">

    <div class="sidebar">

        <div class="logo">
            <h2>CV Builder</h2>
        </div>

        <ul>
            <li><a href="#">🏠 Dashboard</a></li>
            <li><a href="/my-cvs">📄 My CVs</a></li>
            <li><a href="/create-cv">➕ Create CV</a></li>
            <li><a href="/profile">👤 Profile</a></li>
            <li><a href="/logout">🚪 Logout</a></li>
        </ul>

    </div>

    <div class="main-content">

        <div class="top-bar">
            <h1>Welcome Back 👋</h1>
            <p>Ready to build your next professional CV?</p>
        </div>

        <div class="cards">

            <div class="card">
                <h3>📄 Total CVs</h3>
                <span><%= totalCVs %> / 3</span>
            </div>

            <div class="card">
                <h3>⭐ Templates</h3>
                <p>4</p>
            </div>

            <div class="card">
                <h3>🚀 Downloads</h3>
             <span><%= totalDownloads %></span>         
            </div>

        </div>

        <div class="action-section">

            <h2>Create Your Next CV</h2>

            <p>
                Build ATS-friendly resumes and stand out from the crowd.
            </p>

            <a href="/create-cv" class="create-btn">
                Create New CV
            </a>

        </div>

    </div>

</body>
</html>