<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title><%= cv.title %></title>

<link rel="stylesheet" href="/style.css">

<style>

@page{
    size:A4;
    margin:10mm;
}

*{
    -webkit-print-color-adjust:exact;
    print-color-adjust:exact;
}

@media print{

.no-print{
display:none !important;
}

body{
margin:0;
padding:0;
background:white;
}

.resume,
.resume2,
.resume3,
.resume4{

box-shadow:none;
margin:0 auto;

}

section{
page-break-inside:avoid;
}

}

</style>


</head>

<body class="template2-body">

    <input type="hidden" id="isDownload" value="<%= isDownload %>">


<% if (!isPreview && !isDownload) { %>

<div class="resume-actions no-print" class="change-template-btn">

<a href="/print/<%= cv._id %>" target="_blank">
Download PDF
</a>

    <a href="/templates/<%= cv._id %>" class="change-template-btn">
        Change Template
    </a>

</div>

<% } %>

<div class="resume2">

    <!-- LEFT SIDEBAR -->

    <aside class="sidebar2">

        <h2><%= cv.personalInfo.fullname %></h2>

        <p class="job-title">
            <%= cv.title %> 
        </p>

        <div class="side-section">

            <h3>CONTACT</h3>

            <p>📧 <%= cv.personalInfo.email %></p>

            <p>📞 <%= cv.personalInfo.phone %></p>

            <p>
                <a href="<%= cv.personalInfo.linkedin %>" target="_blank">
                    LinkedIn
                </a>
            </p>

            <p>
                <a href="<%= cv.personalInfo.github %>" target="_blank">
                    GitHub
                </a>
            </p>

        </div>

        <div class="side-section">

            <h3>SKILLS</h3>

            <% cv.skills.split(",").forEach(skill=>{ %>

                <div class="skill-box">

                    <%= skill.trim() %>

                </div>

            <% }) %>

        </div>

    </aside>

    <!-- RIGHT SIDE -->

    <main class="content2">

        <section>

            <h2>PROFILE</h2>

            <p>
                Passionate software developer interested in
                full-stack web development and problem solving.
            </p>

        </section>

        <section>

            <h2>EDUCATION</h2>

            <h3><%= cv.education.college %></h3>

            <p><%= cv.education.degree %></p>

            <p>CGPA : <%= cv.education.cgpa %></p>

        </section>

        <section>

            <h2>PROJECTS</h2>

            <p><%= cv.projects || "No Projects Added" %></p>

        </section>

        <section>

            <h2>EXPERIENCE</h2>

            <p><%= cv.experience || "No Experience Added" %></p>

        </section>

        

    </main>

</div>

<script>

window.addEventListener("load", function () {

    const input = document.getElementById("isDownload");

    if (input && input.value === "true") {

        setTimeout(() => {
            window.print();
        }, 300);

    }

});

</script>

</body>
</html>