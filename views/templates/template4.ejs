<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title><%= cv.title %></title>

<link rel="stylesheet" href="/style.css">

<style>

@page{
    size:A4;
    margin:10mm;
}

*{
    -webkit-print-color-adjust:exact;
    print-color-adjust:exact;
}

@media print{

.no-print{
display:none !important;
}

body{
margin:0;
padding:0;
background:white;
}

.resume,
.resume2,
.resume3,
.resume4{

box-shadow:none;
margin:0 auto;

}

section{
page-break-inside:avoid;
}

}

</style>
</head>
<body class="template4-body">

    <input type="hidden" id="isDownload" value="<%= isDownload %>">

    <% if (!isPreview && !isDownload) { %>

<div class="resume-actions no-print">

    <a href="/print/<%= cv._id %>" target="_blank" class="change-template-btn">
Download PDF
</a>

    <a href="/templates/<%= cv._id %>" class="change-template-btn">
        Change Template
    </a>

</div>

<% } %>

<div class="resume4">

<header>

<h1><%= cv.personalInfo.fullname %></h1>

<p>  
     <%= cv.title %> 
</p>

</header>

<div class="grid2">

<div>

<h2>CONTACT</h2>

<p><%= cv.personalInfo.email %></p>

<p><%= cv.personalInfo.phone %></p>

<p><%= cv.personalInfo.linkedin %></p>

<p><%= cv.personalInfo.github %></p>

</div>

<div>

<h2>EDUCATION</h2>

<h3><%= cv.education.college %></h3>

<p><%= cv.education.degree %></p>

<p>CGPA : <%= cv.education.cgpa %></p>

</div>

</div>

<section>

<h2>SKILLS</h2>

<div class="skill-list">

<% cv.skills.split(",").forEach(skill=>{ %>

<span><%= skill.trim() %></span>

<% }) %>

</div>

</section>

<section>

<h2>PROJECTS</h2>

<p>

<%= cv.projects || "No Projects Added" %>

</p>

</section>

<section>

<h2>EXPERIENCE</h2>

<p>

<%= cv.experience || "No Experience Added" %>

</p>

</section>


</div>

<script>

window.addEventListener("load", function () {

    const input = document.getElementById("isDownload");

    if (input && input.value === "true") {

        setTimeout(() => {
            window.print();
        }, 300);

    }

});

</script>

</body>

</html>