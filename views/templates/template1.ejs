<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title><%= cv.title %></title>

<link rel="stylesheet" href="/style.css">

</head>

<body class="resume-body">

    <% if (!isPreview && !isDownload) { %>

<div class="resume-actions no-print">

    <a href="/download/<%= cv._id %>" class="download-btn">
    Download PDF
</a>

    <a href="/templates/<%= cv._id %>" class="change-template-btn">
        Change Template
    </a>

</div>

<% } %>

<div class="resume-container">

    <!-- Header -->

    <div class="resume-header">

        <h1><%= cv.personalInfo.fullname %></h1>

        <p class="resume-role">
            <%= cv.title %> 
        </p>

        <div class="contact-info">

            <span>📧 <%= cv.personalInfo.email %></span>

            <span>📞 <%= cv.personalInfo.phone %></span>

        </div>

        <div class="contact-links">

            <a href="<%= cv.personalInfo.linkedin %>" target="_blank">
                LinkedIn
            </a>

            |

            <a href="<%= cv.personalInfo.github %>" target="_blank">
                GitHub
            </a>

        </div>

    </div>

    <!-- Education -->

    <section>

        <h2>Education</h2>

        <div class="section-content">

            <h3><%= cv.education.college %></h3>

            <p><%= cv.education.degree %></p>

            <p><strong>CGPA :</strong> <%= cv.education.cgpa %></p>

        </div>

    </section>

    <!-- Skills -->

    <section>

        <h2>Skills</h2>

        <div class="skills">

        <% cv.skills.split(',').forEach(skill=>{ %>

            <span class="skill">

                <%= skill.trim() %>

            </span>

        <% }) %>

        </div>

    </section>

    <!-- Projects -->

    <section>

        <h2>Projects</h2>

        <div class="section-content">

            <p><%= cv.projects || "No Projects Added" %></p>

        </div>

    </section>

    <!-- Experience -->

    <section>

        <h2>Experience</h2>

        <div class="section-content">

            <p><%= cv.experience || "No Experience Added" %></p>

        </div>

    </section>

    

</div>


</body>
</html>