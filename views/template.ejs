<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Choose Template</title>

    <link rel="stylesheet" href="/style.css">
</head>

<body class="template-body">

<div class="template-page">

    <div class="template-header">

        <h1>Choose Your Resume Template</h1>

        <p>
            Select one of our professional ATS-friendly resume templates.
        </p>

    </div>

    <div class="template-grid">

        <!-- Template 1 -->
        <div class="resume-card">

            <div class="resume-preview">
                Resume Preview
            </div>

            <div class="resume-info">

                <h3>Classic Professional</h3>

                <span>ATS Friendly</span>

                <div class="buttons">

                    <a href="/preview/template1/<%= cv._id %>" class="preview-btn">
                        Preview
                    </a>

                    <a href="/select-template/<%= cv._id %>/1" class="use-btn">
                        Use Template
                    </a>

                </div>

            </div>

        </div>

        <!-- Template 2 -->

        <div class="resume-card">

            <div class="resume-preview">
                Resume Preview
            </div>

            <div class="resume-info">

                <h3>Modern Sidebar</h3>

                <span>Creative Layout</span>

                <div class="buttons">

                    <a href="/preview/template2/<%= cv._id %>" class="preview-btn">
                        Preview
                    </a>

                    <a href="/select-template/<%= cv._id %>/2" class="use-btn">
                        Use Template
                    </a>

                </div>

            </div>

        </div>

        <!-- Template 3 -->

        <div class="resume-card">

            <div class="resume-preview">
                Resume Preview
            </div>

            <div class="resume-info">

                <h3>Executive</h3>

                <span>Professional Layout</span>

                <div class="buttons">

                    <a href="/preview/template3/<%= cv._id %>" class="preview-btn">
                        Preview
                    </a>

                    <a href="/select-template/<%= cv._id %>/3" class="use-btn">
                        Use Template
                    </a>

                </div>

            </div>

        </div>

        <!-- Template 4 -->

        <div class="resume-card">

            <div class="resume-preview">
                Resume Preview
            </div>

            <div class="resume-info">

                <h3>Modern Minimal</h3>

                <span>ATS friendly</span>

                <div class="buttons">

                    <a href="/preview/template4/<%= cv._id %>" class="preview-btn">
                        Preview
                    </a>

                    <a href="/select-template/<%= cv._id %>/4" class="use-btn">
                        Use Template
                    </a>

                </div>

            </div>

        </div>

    </div>

</div>

</body>
</html>